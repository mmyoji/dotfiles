[core]
  editor = vim

[user]
  name  = mmyoji
  email = mmyoji@example.com

[alias]
  a   = add
  aa  = add --all
  b   = branch
  cma = commit --amend --verbose
  com = commit --verbose
  d   = diff
  dw  = diff --word-diff-regex=. --word-diff=color
  l   = log --graph
  lo  = log --oneline
  pf  = push --force
  ps  = push --set-upstream
  r   = rebase
  s   = status --short --branch
  sw  = !git branch | fzf | xargs git switch
  swc = switch --create

  search          = log --perl-regexp -S
  show-conflicted = diff --name-only --diff-filter=U
  vtree           = log --pretty=oneline --graph --decorate --all

[commit]
  template = ~/.config/git/commit_template

[diff]
  indentHeuristic = true

[fetch]
  prune = true

[init]
  defaultBranch = main

[log]
  abbrevCommit = true

[pull]
  rebase = false

[push]
  default = simple

[rebase]
  autosquash = true
  autostash  = true

[github]
  user = mmyoji

